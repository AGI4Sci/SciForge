      "rounds": [
        {"round": 1, "prompt": "从桌面启动任意文字处理应用，用通用鼠标键盘创建一页说明文档。", "expectedTrace": ["app launch screenshots", "text insertion actions", "save panel refs"]},
        {"round": 2, "prompt": "切换到演示应用，创建一页“GUI Agent 能力地图”幻灯片，包含标题、三栏结构、至少一个图形或文本框。", "expectedTrace": ["window switch refs", "slide canvas grounding", "shape/text box actions"]},
        {"round": 3, "prompt": "在文件管理器中视觉定位刚才生成的两个文件，重命名到统一前缀并移动到测试目录。", "expectedTrace": ["file manager screenshots", "rename/move action ledger", "test directory ref"]},
        {"round": 4, "prompt": "回到 SciForge，根据 trace 文件引用回答哪个动作最不稳定、哪一步需要更好的 grounding、哪些截图可复现。", "expectedTrace": ["trace refs reused", "instability summary", "no screenshot payload"]}
      ],
      "acceptance": ["两个应用均只通过通用 action schema 执行", "appSpecificShortcuts=[]", "保存/重命名/移动均有 before/after screenshot refs", "无 base64/dataUrl", "无 DOM/accessibility 字段"],
      "failureRecord": ["planner/grounder/verifier 问题分类", "保存面板截图", "菜单文案变化", "不写应用补丁绕过"],
      "requiredEvidence": ["vision-trace.json", "windowTarget metadata", "window screenshot refs", "window-local coordinates", "input channel", "scheduler metadata", "before/after screenshots", "action ledger", "failure diagnostics", "follow-up image memory reuse"]
