    {
      "id": "CU-LONG-004",
      "title": "长表单与菜单密集 UI 操作",
      "goal": "验证复杂表单填写、状态识别、校验错误读取和字段修正。",
      "minRounds": 4,
      "requiredPipeline": ["WindowTarget", "VisionPlanner", "Grounder", "GuiExecutor", "Verifier", "vision-trace"],
      "safetyBoundary": {"noDomAccessibility": true, "fileRefOnlyImageMemory": true, "failClosedHighRiskActions": true, "appSpecificShortcutsAllowed": false},
      "rounds": [
        {"round": 1, "prompt": "打开平台设置/偏好设置或当前窗口中已经可见的设置/表单区域，只执行低风险视觉操作：定位至少 8 个可见控件并覆盖文本框/搜索框、下拉或弹出菜单、复选框、切换开关、按钮；允许填写测试文本、展开菜单、滚动和取消/关闭弹层，但不要提交会改变账号、网络、安全或付费状态的操作。", "expectedTrace": ["eight field/control states", "control-specific actions", "verifier checks"]},
        {"round": 2, "prompt": "基于上一轮截图 refs 重新定位同一设置/表单区域，视觉修改或重新检查其中 3 个低风险控件；每个字段必须先记录 before screenshot，再执行通用 GUI action，最后记录 after screenshot，不能从内部状态直接假设页面内容。", "expectedTrace": ["field before screenshots", "three updates", "after state screenshots"]},
        {"round": 3, "prompt": "在本地可见表单或设置搜索框中制造一个低风险校验/无结果状态（例如输入明显无效的测试值或不存在的搜索词），读取屏幕错误/空结果状态，随后用视觉方式清除或修正该字段；不要点击高风险提交、保存或授权按钮。", "expectedTrace": ["validation or empty-state screenshot", "repair action", "post-repair verifier"]},
        {"round": 4, "prompt": "让 SciForge 总结每个字段/控件的视觉证据和对应 action，只引用 screenshot refs、窗口目标、坐标和 action ledger；不允许出现 DOM selector 或 accessibility label。", "expectedTrace": ["field evidence refs", "action mapping", "no DOM/accessibility labels"]}
      ],
      "acceptance": ["至少 20 个通用动作", "至少 3 次 verifier 判断", "至少 1 次错误恢复", "所有字段状态来自 screenshot refs", "无 base64/dataUrl", "无 DOM/accessibility 字段"],
      "failureRecord": ["焦点前后截图", "输入动作", "预期字段", "实际变化区域", "修正动作"],
      "requiredEvidence": ["vision-trace.json", "windowTarget metadata", "window screenshot refs", "window-local coordinates", "input channel", "scheduler metadata", "before/after screenshots", "action ledger", "failure diagnostics", "follow-up image memory reuse"]
