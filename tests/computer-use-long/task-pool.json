{
  "schemaVersion": "1.0",
  "taskId": "T084",
  "title": "长时复杂 Computer Use 测试任务池",
  "commonPrinciples": [
    "所有任务必须走 WindowTarget -> VisionPlanner -> Grounder -> GuiExecutor -> Verifier -> vision-trace 主路径。",
    "不得读取 DOM 或 accessibility tree，不得通过应用私有 API、脚本或文件生成接口绕过 GUI。",
    "若 WindowTarget、VisionPlanner、Grounder、GuiExecutor 或 Verifier 任一依赖缺失，必须结构化 failed-with-reason，并记录真实 window screenshot refs。",
    "多轮上下文只允许保留 trace path、window screenshot file refs、sha256、尺寸、windowTarget、input channel、scheduler metadata、action ledger 和轻量摘要，不允许内联 dataUrl/base64 图片。"
  ],
  "scenarios": [
    {
      "id": "CU-LONG-001",
      "title": "跨浏览器科研检索与证据整理",
      "goal": "验证浏览器科研检索、结果筛选、滚动恢复、窗口切换和 follow-up image memory。",
      "minRounds": 4,
      "requiredPipeline": ["WindowTarget", "VisionPlanner", "Grounder", "GuiExecutor", "Verifier", "vision-trace"],
      "safetyBoundary": {"noDomAccessibility": true, "fileRefOnlyImageMemory": true, "failClosedHighRiskActions": true, "appSpecificShortcutsAllowed": false},
      "rounds": [
        {"round": 1, "prompt": "在浏览器中打开新的检索页面，搜索指定科研主题，视觉定位搜索框、结果列表、过滤器和打开链接动作。", "expectedTrace": ["before/after screenshot refs", "search box grounding", "result list grounding"]},
        {"round": 2, "prompt": "在当前页面继续筛选 3 条候选证据，根据屏幕内容规划点击、滚动、返回、切换标签页。", "expectedTrace": ["scroll action ledger", "tab/window state", "three candidate evidence locations"]},
        {"round": 3, "prompt": "回到 SciForge 聊天，用上一轮 trace 文件引用总结页面状态、已访问证据位置和下一步动作。", "expectedTrace": ["follow-up image memory refs", "no inline screenshot payload"]},
        {"round": 4, "prompt": "故意切换浏览器窗口或移动到另一个显示器，验证 display selection、window targeting 和恢复策略。", "expectedTrace": ["display/window metadata", "recovery action", "final screenshot ref"]}
      ],
      "acceptance": ["至少 12 个通用动作", "至少 2 个 display/window 状态变化", "至少 1 次滚动恢复", "无 base64/dataUrl", "无 DOM/accessibility 字段"],
      "failureRecord": ["target description", "预测坐标", "crosshair screenshot", "修正目标描述", "重试结果"],
      "requiredEvidence": ["vision-trace.json", "windowTarget metadata", "window screenshot refs", "window-local coordinates", "input channel", "scheduler metadata", "before/after screenshots", "action ledger", "failure diagnostics", "follow-up image memory reuse"]
    },
    {
      "id": "CU-LONG-002",
      "title": "Office 文档与演示的跨应用通用操作",
      "goal": "验证文字处理、演示应用、文件管理器之间的跨应用 GUI 操作不依赖应用补丁。",
