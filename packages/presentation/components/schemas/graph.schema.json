{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sciforge.local/schemas/ui-primitives/graph.schema.json",
  "title": "SciForge graph primitive",
  "type": "object",
  "required": ["primitive", "nodes", "edges"],
  "properties": {
    "primitive": { "const": "graph" },
    "schemaVersion": { "type": "string", "default": "0.1.0" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "preset": { "type": "string", "examples": ["knowledge-graph"] },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "target": { "type": "string" },
          "relation": { "type": "string" },
          "confidence": { "type": "number" }
        },
        "additionalProperties": true
      }
    },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true,
  "examples": [
    {
      "primitive": "graph",
      "schemaVersion": "0.1.0",
      "id": "knowledge-demo",
      "title": "Target knowledge graph",
      "preset": "knowledge-graph",
      "nodes": [
        { "id": "g1", "label": "Gene A", "type": "gene" },
        { "id": "d1", "label": "Drug X", "type": "drug" }
      ],
      "edges": [
        { "source": "d1", "target": "g1", "relation": "targets", "confidence": 0.62 }
      ]
    }
  ]
}
