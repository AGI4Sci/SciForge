{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sciforge.local/schemas/ui-primitives/editable-design.schema.json",
  "title": "SciForge editable-design primitive",
  "type": "object",
  "required": ["primitive", "designType"],
  "properties": {
    "primitive": { "const": "editable-design" },
    "schemaVersion": { "type": "string", "default": "0.1.0" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "designType": { "type": "string", "examples": ["experiment", "workflow", "diagram", "schema", "prompt", "notebook"] },
    "body": { "type": ["object", "array", "string"], "additionalProperties": true },
    "format": { "type": "string", "examples": ["json", "markdown", "mermaid", "yaml"] },
    "editable": { "type": "boolean", "default": true },
    "revision": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true,
  "examples": [
    {
      "primitive": "editable-design",
      "schemaVersion": "0.1.0",
      "id": "experiment-plan-demo",
      "title": "CRISPR screen design",
      "designType": "experiment",
      "format": "json",
      "editable": true,
      "revision": "r1",
      "body": {
        "objective": "Identify resistance modifiers",
        "arms": ["control", "treated"],
        "replicates": 3
      }
    }
  ]
}
