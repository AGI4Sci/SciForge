{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sciforge.local/schemas/ui-primitives/statistical-result.schema.json",
  "title": "SciForge statistical-result primitive",
  "type": "object",
  "required": ["primitive", "results"],
  "properties": {
    "primitive": { "const": "statistical-result" },
    "schemaVersion": { "type": "string", "default": "0.1.0" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "test": { "type": "string" },
    "modelFormula": { "type": "string" },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "replicateStructure": { "type": "object", "additionalProperties": true },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "estimate": { "type": "number" },
          "statistic": { "type": "number" },
          "pValue": { "type": "number" },
          "adjustedPValue": { "type": "number" },
          "effectSize": { "type": "number" },
          "confidenceInterval": {
            "type": "object",
            "properties": {
              "lower": { "type": "number" },
              "upper": { "type": "number" },
              "level": { "type": "number" }
            },
            "additionalProperties": true
          },
          "n": { "type": "number" },
          "groupSizes": { "type": "object", "additionalProperties": true },
          "linkedPlotTarget": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "plotAnnotations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "summary": { "type": "object", "additionalProperties": true },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true,
  "examples": [
    {
      "primitive": "statistical-result",
      "schemaVersion": "0.1.0",
      "id": "de-demo",
      "title": "Differential expression results",
      "test": "wald",
      "modelFormula": "~ condition + batch",
      "assumptions": ["negative-binomial GLM", "Benjamini-Hochberg FDR"],
      "results": [
        { "id": "GENE1", "estimate": 2.1, "statistic": 5.2, "pValue": 0.00001, "adjustedPValue": 0.0004, "effectSize": 2.1, "confidenceInterval": { "lower": 1.4, "upper": 2.8, "level": 0.95 }, "n": 6 },
        { "id": "GENE2", "estimate": -1.8, "statistic": -4.3, "pValue": 0.0002, "adjustedPValue": 0.004, "n": 6 }
      ],
      "summary": { "significant": 2 }
    }
  ]
}
