{
  "name": "@sciforge-ui/components",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "packages:check": "tsx ../../scripts/check-ui-components-package-boundaries.ts"
  },
  "files": [
    "README.md",
    "index.ts",
    "types.ts",
    "package.json",
    "*/README.md",
    "*/manifest.ts",
    "*/render.tsx",
    "*/fixtures",
    "*/assets",
    "*/workbench-demo"
  ],
  "exports": {
    ".": "./index.ts",
    "./types": "./types.ts",
    "./*/manifest": "./*/manifest.ts",
    "./*/README.md": "./*/README.md",
    "./*/fixtures/basic": "./*/fixtures/basic.ts",
    "./*/fixtures/empty": "./*/fixtures/empty.ts",
    "./*/fixtures/selection": "./*/fixtures/selection.ts",
    "./*/render": "./*/render.tsx",
    "./*/assets/*": "./*/assets/*",
    "./*/workbench-demo/*": "./*/workbench-demo/*",
    "./data-table/render": "./data-table/render.tsx",
    "./report-viewer/render": "./report-viewer/render.tsx"
  }
}
