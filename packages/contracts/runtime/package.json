{
  "name": "@sciforge-ui/runtime-contract",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "description": "Stable SciForge UI component runtime contracts for independently published component packages.",
  "sciforge": {
    "lifecycleLayer": "contracts",
    "skillFacing": false,
    "sideEffects": "none",
    "publicContract": true,
    "runtimeAdapter": false
  },
  "main": "./index.ts",
  "types": "./index.ts",
  "files": [
    "README.md",
    "app.ts",
    "artifacts.ts",
    "events.ts",
    "execution.ts",
    "capabilities.ts",
    "handoff.ts",
    "handoff-payload.ts",
    "index.ts",
    "messages.ts",
    "observe.ts",
    "preview.ts",
    "references.ts",
    "session.ts",
    "stream.ts",
    "view.ts",
    "package.json"
  ],
  "exports": {
    ".": "./index.ts",
    "./app": "./app.ts",
    "./artifacts": "./artifacts.ts",
    "./events": "./events.ts",
    "./execution": "./execution.ts",
    "./capabilities": "./capabilities.ts",
    "./handoff": "./handoff.ts",
    "./handoff-payload": "./handoff-payload.ts",
    "./messages": "./messages.ts",
    "./observe": "./observe.ts",
    "./preview": "./preview.ts",
    "./references": "./references.ts",
    "./session": "./session.ts",
    "./stream": "./stream.ts",
    "./view": "./view.ts"
  },
  "peerDependencies": {
    "react": "^19.2.5"
  }
}
